<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://tools.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/main_bg_gradient">

    <!-- Top AppBar -->
    <com.google.android.material.appbar.AppBarLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@android:color/transparent"
        app:elevation="0dp">

        <com.google.android.material.appbar.MaterialToolbar
            android:id="@+id/toolbar"
            android:layout_width="match_parent"
            android:layout_height="?attr/actionBarSize"
            app:title="@string/app_name"
            app:titleCentered="true"
            app:titleTextColor="@color/white" />
    </com.google.android.material.appbar.AppBarLayout>

    <!-- Content Area -->
    <FrameLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_marginBottom="60dp"
        app:layout_behavior="@string/appbar_scrolling_view_behavior">

        <!-- 1. SOS PANEL -->
        <ScrollView
            android:id="@+id/panel_sos"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:fillViewport="true"
            android:visibility="visible">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="20dp"
                android:gravity="center_horizontal">

                <!-- Modern Status Chip -->
                <com.google.android.material.card.MaterialCardView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    app:cardBackgroundColor="@color/midnight_blue"
                    app:cardCornerRadius="20dp"
                    app:strokeColor="@color/glass_border"
                    app:strokeWidth="1dp"
                    app:cardElevation="0dp">

                </com.google.android.material.card.MaterialCardView>

                <!-- Panic Button Container -->
                <FrameLayout
                    android:id="@+id/panic_section"
                    android:layout_width="280dp"
                    android:layout_height="280dp"
                    android:layout_marginTop="20dp">

                    <View
                        android:id="@+id/panic_ripple"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:background="@drawable/panic_button_selector"
                        android:visibility="invisible" />

                    <com.google.android.material.card.MaterialCardView
                        android:id="@+id/btnPanicContainer"
                        android:layout_width="210dp"
                        android:layout_height="210dp"
                        android:layout_gravity="center"
                        app:cardBackgroundColor="@color/panic_red"
                        app:cardCornerRadius="105dp"
                        app:cardElevation="10dp"
                        app:strokeColor="#50FFFFFF"
                        app:strokeWidth="6dp">

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:gravity="center"
                            android:orientation="vertical">

                            <TextView
                                android:id="@+id/tvPanicTitle"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="SOS"
                                android:textColor="@color/white"
                                android:textSize="44sp"
                                android:textStyle="bold"
                                android:letterSpacing="0.05" />

                            <TextView
                                android:id="@+id/tvPanicSubtitle"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="@string/tap_to_trigger"
                                android:textColor="#E0FFFFFF"
                                android:textSize="13sp"
                                android:layout_marginTop="4dp" />
                        </LinearLayout>
                    </com.google.android.material.card.MaterialCardView>

                    <ProgressBar
                        android:id="@+id/panic_progress"
                        style="?android:attr/progressBarStyleHorizontal"
                        android:layout_width="240dp"
                        android:layout_height="240dp"
                        android:layout_gravity="center"
                        android:indeterminate="false"
                        android:max="100"
                        android:progress="0"
                        android:progressDrawable="@drawable/circular_progress"
                        android:visibility="invisible" />
                </FrameLayout>

                <!-- Active Tracking Card -->
                <com.google.android.material.card.MaterialCardView
                    android:id="@+id/cardActiveTracking"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="20dp"
                    android:visibility="gone"
                    app:cardBackgroundColor="@color/card_bg"
                    app:cardCornerRadius="16dp"
                    app:strokeColor="@color/panic_red"
                    app:strokeWidth="1.5dp"
                    app:cardElevation="0dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:padding="16dp"
                        android:gravity="center_vertical">

                        <ProgressBar
                            android:layout_width="24dp"
                            android:layout_height="24dp"
                            android:indeterminate="true"
                            android:indeterminateTint="@color/panic_red" />

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:layout_marginStart="16dp"
                            android:orientation="vertical">

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Active Live Tracking"
                                android:textColor="@color/panic_red"
                                android:textSize="15sp"
                                android:textStyle="bold" />

                            <TextView
                                android:id="@+id/tvActiveStats"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="4dp"
                                android:text="Location coordinates are updated every 30 seconds."
                                android:textColor="@color/text_secondary"
                                android:textSize="13sp" />
                        </LinearLayout>
                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>

                <!-- Primary Emergency Contact Card -->
                <com.google.android.material.card.MaterialCardView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="20dp"
                    app:cardBackgroundColor="@color/card_bg"
                    app:cardCornerRadius="16dp"
                    app:strokeColor="@color/glass_border"
                    app:strokeWidth="1dp"
                    app:cardElevation="0dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:padding="16dp">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/primary_emergency_contact"
                            android:textColor="@color/text_primary"
                            android:textSize="15sp"
                            android:textStyle="bold" />

                        <!-- Display Info Row -->
                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal"
                            android:layout_marginTop="12dp"
                            android:gravity="center_vertical">

                            <com.google.android.material.card.MaterialCardView
                                android:layout_width="44dp"
                                android:layout_height="44dp"
                                app:cardBackgroundColor="@color/midnight_blue"
                                app:cardCornerRadius="22dp"
                                app:strokeColor="@color/glass_border"
                                app:strokeWidth="1dp"
                                app:cardElevation="0dp">
                                <ImageView
                                    android:layout_width="20dp"
                                    android:layout_height="20dp"
                                    android:src="@drawable/ic_person"
                                    android:layout_gravity="center"
                                    app:tint="@color/m3_primary" />
                            </com.google.android.material.card.MaterialCardView>

                            <TextView
                                android:id="@+id/tvPrimaryContactDisplay"
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:layout_marginStart="16dp"
                                android:textColor="@color/white"
                                android:textSize="14sp"
                                android:lineSpacingMultiplier="1.2" />
                        </LinearLayout>

                        <!-- Form Layout (Hidden or Collapsible, but accessible via Edit Contact) -->
                        <LinearLayout
                            android:id="@+id/layoutPrimaryContactEdit"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="vertical"
                            android:layout_marginTop="16dp"
                            android:visibility="gone">

                            <com.google.android.material.textfield.TextInputLayout
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:hint="Contact Name"
                                app:startIconDrawable="@drawable/ic_person"
                                app:startIconTint="@color/text_secondary"
                                style="@style/Widget.Material3.TextInputLayout.OutlinedBox">

                                <com.google.android.material.textfield.TextInputEditText
                                    android:id="@+id/etPrimaryName"
                                    android:layout_width="match_parent"
                                    android:layout_height="wrap_content"
                                    android:textColor="@color/white"
                                    android:inputType="textPersonName" />
                            </com.google.android.material.textfield.TextInputLayout>

                            <com.google.android.material.textfield.TextInputLayout
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="12dp"
                                android:hint="Phone Number"
                                app:startIconDrawable="@drawable/ic_phone"
                                app:startIconTint="@color/text_secondary"
                                style="@style/Widget.Material3.TextInputLayout.OutlinedBox">

                                <com.google.android.material.textfield.TextInputEditText
                                    android:id="@+id/etPrimaryPhone"
                                    android:layout_width="match_parent"
                                    android:layout_height="wrap_content"
                                    android:textColor="@color/white"
                                    android:inputType="phone" />
                            </com.google.android.material.textfield.TextInputLayout>
                        </LinearLayout>

                        <!-- Buttons Row -->
                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal"
                            android:layout_marginTop="16dp"
                            android:gravity="end">

                            <com.google.android.material.button.MaterialButton
                                android:id="@+id/btnEditPrimary"
                                style="@style/Widget.Material3.Button.OutlinedButton"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Edit Contact"
                                android:textColor="@color/white"
                                app:strokeColor="@color/glass_border" />

                            <com.google.android.material.button.MaterialButton
                                android:id="@+id/btnSavePrimary"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginStart="8dp"
                                android:text="Save Contact"
                                android:textColor="@color/white"
                                app:backgroundTint="@color/m3_primary"
                                android:visibility="gone"
                                style="@style/Widget.Material3.Button" />
                        </LinearLayout>
                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>

            </LinearLayout>
        </ScrollView>

        <!-- 2. HISTORY PANEL -->
        <LinearLayout
            android:id="@+id/panel_history"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:orientation="vertical"
            android:padding="16dp"
            android:visibility="gone">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginBottom="16dp"
                android:text="Emergency Timeline &amp; History"
                android:textColor="@color/white"
                android:textSize="20sp"
                android:textStyle="bold" />

            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/rvHistory"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:scrollbars="vertical"
                tools:listitem="@android:layout/simple_list_item_2" />
        </LinearLayout>

        <!-- 3. SETTINGS PANEL -->
        <ScrollView
            android:id="@+id/panel_settings"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:visibility="gone">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp">

                <!-- Profile Section -->
                <com.google.android.material.card.MaterialCardView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="16dp"
                    app:cardBackgroundColor="@color/card_bg"
                    app:cardCornerRadius="16dp"
                    app:strokeColor="@color/glass_border"
                    app:strokeWidth="1dp"
                    app:cardElevation="0dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:padding="16dp">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Profile Details"
                            android:textColor="@color/text_primary"
                            android:textSize="15sp"
                            android:textStyle="bold" />

                        <com.google.android.material.textfield.TextInputLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="12dp"
                            android:hint="Your Full Name"
                            app:startIconDrawable="@drawable/ic_person"
                            app:startIconTint="@color/text_secondary"
                            style="@style/Widget.Material3.TextInputLayout.OutlinedBox">

                            <com.google.android.material.textfield.TextInputEditText
                                android:id="@+id/etUserNameSetting"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:inputType="textPersonName"
                                android:textColor="@color/white" />
                        </com.google.android.material.textfield.TextInputLayout>

                        <com.google.android.material.textfield.TextInputLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="12dp"
                            android:hint="Custom SOS SMS Message Template"
                            app:startIconDrawable="@drawable/ic_sos"
                            app:startIconTint="@color/text_secondary"
                            style="@style/Widget.Material3.TextInputLayout.OutlinedBox">

                            <com.google.android.material.textfield.TextInputEditText
                                android:id="@+id/etMessageSetting"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:inputType="textMultiLine"
                                android:textColor="@color/white" />
                        </com.google.android.material.textfield.TextInputLayout>
                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>

                <!-- Trigger settings -->
                <com.google.android.material.card.MaterialCardView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="16dp"
                    app:cardBackgroundColor="@color/card_bg"
                    app:cardCornerRadius="16dp"
                    app:strokeColor="@color/glass_border"
                    app:strokeWidth="1dp"
                    app:cardElevation="0dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:padding="16dp">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="SOS Activation Triggers"
                            android:textColor="@color/text_primary"
                            android:textSize="15sp"
                            android:textStyle="bold" />

                        <com.google.android.material.materialswitch.MaterialSwitch
                            android:id="@+id/cbPowerTriple"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="12dp"
                            android:text="Power Button Triple Press (Default)"
                            android:textColor="@color/white" />

                        <com.google.android.material.materialswitch.MaterialSwitch
                            android:id="@+id/cbLongPress"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="8dp"
                            android:text="Long Press SOS Button"
                            android:textColor="@color/white" />

                        <com.google.android.material.materialswitch.MaterialSwitch
                            android:id="@+id/cbVolumeCombo"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="8dp"
                            android:text="Rapid Volume Button Clicks"
                            android:textColor="@color/white" />

                        <com.google.android.material.materialswitch.MaterialSwitch
                            android:id="@+id/cbShakeTrigger"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="8dp"
                            android:text="Device Shake Sensor Trigger"
                            android:textColor="@color/white" />

                        <com.google.android.material.materialswitch.MaterialSwitch
                            android:id="@+id/cbVoiceTrigger"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="8dp"
                            android:text="Voice Activation (Say 'Help Me')"
                            android:textColor="@color/white" />
                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>

                <!-- Response Options -->
                <com.google.android.material.card.MaterialCardView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="16dp"
                    app:cardBackgroundColor="@color/card_bg"
                    app:cardCornerRadius="16dp"
                    app:strokeColor="@color/glass_border"
                    app:strokeWidth="1dp"
                    app:cardElevation="0dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:padding="16dp">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Emergency Response Details"
                            android:textColor="@color/text_primary"
                            android:textSize="15sp"
                            android:textStyle="bold" />

                        <RadioGroup
                            android:id="@+id/rgAlertVolume"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="12dp"
                            android:orientation="horizontal">

                            <RadioButton
                                android:id="@+id/rbLoud"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginEnd="24dp"
                                android:text="Loud Mode"
                                android:textColor="@color/white"
                                android:buttonTint="@color/m3_primary" />

                            <RadioButton
                                android:id="@+id/rbSilent"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Silent Mode"
                                android:textColor="@color/white"
                                android:buttonTint="@color/m3_primary" />
                        </RadioGroup>

                        <com.google.android.material.materialswitch.MaterialSwitch
                            android:id="@+id/cbSiren"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="12dp"
                            android:text="Play Audio Siren sound"
                            android:textColor="@color/white" />

                        <com.google.android.material.materialswitch.MaterialSwitch
                            android:id="@+id/cbFlashlight"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="8dp"
                            android:text="Flash Camera Torch Light Strobe"
                            android:textColor="@color/white" />

                        <com.google.android.material.textfield.TextInputLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="12dp"
                            android:hint="Periodic Tracking SMS Interval (seconds)"
                            app:startIconDrawable="@drawable/ic_timeline"
                            app:startIconTint="@color/text_secondary"
                            style="@style/Widget.Material3.TextInputLayout.OutlinedBox">

                            <com.google.android.material.textfield.TextInputEditText
                                android:id="@+id/etSmsInterval"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:inputType="number"
                                android:textColor="@color/white" />
                        </com.google.android.material.textfield.TextInputLayout>
                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>

                <!-- Emergency Calling Card -->
                <com.google.android.material.card.MaterialCardView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="16dp"
                    app:cardBackgroundColor="@color/card_bg"
                    app:cardCornerRadius="16dp"
                    app:strokeColor="@color/glass_border"
                    app:strokeWidth="1dp"
                    app:cardElevation="0dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:padding="16dp">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Emergency Calling"
                            android:textColor="@color/text_primary"
                            android:textSize="15sp"
                            android:textStyle="bold" />

                        <TextView
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="4dp"
                            android:text="Automatically place a call to your selected emergency contact after SOS activation. Disable this option if you prefer silent emergency alerts."
                            android:textColor="@color/text_secondary"
                            android:textSize="13sp" />

                        <com.google.android.material.materialswitch.MaterialSwitch
                            android:id="@+id/cbEnableCalling"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="12dp"
                            android:text="Enable Emergency Calling"
                            android:textColor="@color/white" />

                        <!-- Contact Selector Spinner -->
                        <LinearLayout
                            android:id="@+id/layoutCallingContact"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="vertical"
                            android:layout_marginTop="12dp">

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Emergency Call Contact"
                                android:textColor="@color/text_secondary"
                                android:textSize="12sp" />

                            <com.google.android.material.card.MaterialCardView
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="4dp"
                                app:cardBackgroundColor="@color/midnight_blue"
                                app:cardCornerRadius="8dp"
                                app:strokeColor="@color/glass_border"
                                app:strokeWidth="1dp"
                                app:cardElevation="0dp">
                                <Spinner
                                    android:id="@+id/spCallingContact"
                                    android:layout_width="match_parent"
                                    android:layout_height="48dp"
                                    android:textColor="@color/white"
                                    android:backgroundTint="@color/white" />
                            </com.google.android.material.card.MaterialCardView>
                        </LinearLayout>

                        <!-- Delay Selector Spinner -->
                        <LinearLayout
                            android:id="@+id/layoutCallingDelay"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="vertical"
                            android:layout_marginTop="12dp">

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Call Delay"
                                android:textColor="@color/text_secondary"
                                android:textSize="12sp" />

                            <com.google.android.material.card.MaterialCardView
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="4dp"
                                app:cardBackgroundColor="@color/midnight_blue"
                                app:cardCornerRadius="8dp"
                                app:strokeColor="@color/glass_border"
                                app:strokeWidth="1dp"
                                app:cardElevation="0dp">
                                <Spinner
                                    android:id="@+id/spCallingDelay"
                                    android:layout_width="match_parent"
                                    android:layout_height="48dp"
                                    android:textColor="@color/white"
                                    android:backgroundTint="@color/white" />
                            </com.google.android.material.card.MaterialCardView>
                        </LinearLayout>

                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>

                <!-- Contacts manager -->
                <com.google.android.material.card.MaterialCardView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="16dp"
                    app:cardBackgroundColor="@color/card_bg"
                    app:cardCornerRadius="16dp"
                    app:strokeColor="@color/glass_border"
                    app:strokeWidth="1dp"
                    app:cardElevation="0dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:padding="16dp">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Emergency Contacts List"
                            android:textColor="@color/text_primary"
                            android:textSize="15sp"
                            android:textStyle="bold" />

                        <!-- Form to Add Contact -->
                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="12dp"
                            android:orientation="horizontal">

                            <com.google.android.material.textfield.TextInputLayout
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1.2"
                                android:hint="Name"
                                style="@style/Widget.Material3.TextInputLayout.OutlinedBox">

                                <com.google.android.material.textfield.TextInputEditText
                                    android:id="@+id/etNewContactName"
                                    android:layout_width="match_parent"
                                    android:layout_height="wrap_content"
                                    android:textColor="@color/white" />
                            </com.google.android.material.textfield.TextInputLayout>

                            <com.google.android.material.textfield.TextInputLayout
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_marginStart="6dp"
                                android:layout_weight="1.5"
                                android:hint="Phone"
                                style="@style/Widget.Material3.TextInputLayout.OutlinedBox">

                                <com.google.android.material.textfield.TextInputEditText
                                    android:id="@+id/etNewContactPhone"
                                    android:layout_width="match_parent"
                                    android:layout_height="wrap_content"
                                    android:inputType="phone"
                                    android:textColor="@color/white" />
                            </com.google.android.material.textfield.TextInputLayout>

                            <com.google.android.material.textfield.TextInputLayout
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_marginStart="6dp"
                                android:layout_weight="0.8"
                                android:hint="Pri"
                                style="@style/Widget.Material3.TextInputLayout.OutlinedBox">

                                <com.google.android.material.textfield.TextInputEditText
                                    android:id="@+id/etNewContactPriority"
                                    android:layout_width="match_parent"
                                    android:layout_height="wrap_content"
                                    android:inputType="number"
                                    android:textColor="@color/white" />
                            </com.google.android.material.textfield.TextInputLayout>

                            <!-- Add Contact IconButton -->
                            <com.google.android.material.button.MaterialButton
                                android:id="@+id/btnAddContact"
                                style="@style/Widget.Material3.Button.IconButton.Filled"
                                android:layout_width="44dp"
                                android:layout_height="44dp"
                                android:layout_gravity="center_vertical"
                                android:layout_marginStart="6dp"
                                android:contentDescription="Add Contact"
                                app:icon="@drawable/ic_add"
                                app:iconSize="20dp"
                                app:iconGravity="textStart"
                                app:iconPadding="0dp"
                                app:backgroundTint="@color/accent_blue" />

                            <!-- Import Contact IconButton -->
                            <com.google.android.material.button.MaterialButton
                                android:id="@+id/btnImportContact"
                                style="@style/Widget.Material3.Button.IconButton.Filled"
                                android:layout_width="44dp"
                                android:layout_height="44dp"
                                android:layout_gravity="center_vertical"
                                android:layout_marginStart="4dp"
                                android:contentDescription="Import Contact"
                                app:icon="@drawable/ic_person"
                                app:iconSize="20dp"
                                app:iconGravity="textStart"
                                app:iconPadding="0dp"
                                app:backgroundTint="@color/accent_green" />
                        </LinearLayout>

                        <!-- Contacts RecyclerView -->
                        <androidx.recyclerview.widget.RecyclerView
                            android:id="@+id/rvContacts"
                            android:layout_width="match_parent"
                            android:layout_height="200dp"
                            android:layout_marginTop="16dp"
                            android:scrollbars="vertical" />

                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>

                <!-- Cloud Integration (Optional) Card -->
                <com.google.android.material.card.MaterialCardView
                    android:id="@+id/cardCloudIntegration"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="12dp"
                    android:clickable="true"
                    android:focusable="true"
                    android:foreground="?attr/selectableItemBackground"
                    app:cardBackgroundColor="@color/card_bg"
                    app:cardCornerRadius="16dp"
                    app:strokeColor="@color/glass_border"
                    app:strokeWidth="1dp"
                    app:cardElevation="0dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:padding="16dp">

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal"
                            android:gravity="center_vertical">

                            <ImageView
                                android:layout_width="20dp"
                                android:layout_height="20dp"
                                android:src="@drawable/ic_person"
                                app:tint="@color/accent_blue" />

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginStart="16dp"
                                android:text="Cloud Sync"
                                android:textColor="@color/text_primary"
                                android:textSize="15sp"
                                android:textStyle="bold" />

                            <!-- Modern badge -->
                            <com.google.android.material.card.MaterialCardView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginStart="12dp"
                                app:cardCornerRadius="6dp"
                                app:strokeWidth="1dp"
                                app:strokeColor="@color/glass_border"
                                app:cardElevation="0dp"
                                app:cardBackgroundColor="@color/midnight_blue">
                                <TextView
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:paddingHorizontal="8dp"
                                    android:paddingVertical="2dp"
                                    android:text="Coming Soon"
                                    android:textColor="@color/text_secondary"
                                    android:textSize="10sp"
                                    android:textStyle="bold" />
                            </com.google.android.material.card.MaterialCardView>
                        </LinearLayout>

                        <TextView
                            android:id="@+id/tvCloudStatus"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="8dp"
                            android:text="Offline Mode (Data saved locally)"
                            android:textColor="@color/text_secondary"
                            android:textSize="13sp" />
                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>

                <!-- About SOS Alerter Entry Card -->
                <com.google.android.material.card.MaterialCardView
                    android:id="@+id/cardAboutApp"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="16dp"
                    android:clickable="true"
                    android:focusable="true"
                    android:foreground="?attr/selectableItemBackground"
                    app:cardBackgroundColor="@color/card_bg"
                    app:cardCornerRadius="16dp"
                    app:strokeColor="@color/glass_border"
                    app:strokeWidth="1dp"
                    app:cardElevation="0dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:padding="16dp"
                        android:gravity="center_vertical">

                        <ImageView
                            android:layout_width="20dp"
                            android:layout_height="20dp"
                            android:src="@drawable/ic_info"
                            app:tint="@color/accent_green" />

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:layout_marginStart="16dp"
                            android:orientation="vertical">

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Version, License, Contributors &amp; Project Info"
                                android:textColor="@color/text_secondary"
                                android:textSize="13sp"
                                android:layout_marginTop="2dp" />
                        </LinearLayout>

                        <ImageView
                            android:layout_width="20dp"
                            android:layout_height="20dp"
                            android:src="@drawable/ic_chevron_right"
                            app:tint="@color/text_secondary" />
                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>

            </LinearLayout>
        </ScrollView>
    </FrameLayout>

</androidx.coordinatorlayout.widget.CoordinatorLayout>
