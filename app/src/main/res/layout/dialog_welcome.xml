<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:padding="20dp"
    android:scrollbars="none">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:gravity="center_horizontal">

        <ImageView
            android:layout_width="64dp"
            android:layout_height="64dp"
            android:src="@drawable/ic_guardian"
            app:tint="@color/panic_red"
            android:layout_marginTop="8dp" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Welcome to SOS Alerter"
            android:textColor="@color/text_primary"
            android:textSize="22sp"
            android:textStyle="bold"
            android:layout_marginTop="16dp"
            android:gravity="center" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Protect. Alert. Respond."
            android:textColor="@color/accent_green"
            android:textSize="12sp"
            android:textStyle="bold"
            android:letterSpacing="0.08"
            android:layout_marginTop="4dp"
            android:gravity="center" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="SOS Alerter is a privacy-focused emergency assistance application designed to help users quickly notify trusted contacts and share their location during emergencies."
            android:textColor="@color/text_secondary"
            android:textSize="14sp"
            android:layout_marginTop="16dp"
            android:gravity="center"
            android:lineSpacingMultiplier="1.2" />

        <!-- Features Divider -->
        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:background="@color/glass_white"
            android:layout_marginTop="16dp"
            android:layout_marginBottom="16dp" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Main Features:"
            android:textColor="@color/text_primary"
            android:textSize="15sp"
            android:textStyle="bold" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="• Emergency SMS Alerts\n• Live GPS Location Sharing\n• Emergency Calling\n• Emergency Contact Management\n• Audio Recording\n• Photo Capture\n• Offline Emergency Support"
            android:textColor="@color/text_secondary"
            android:textSize="14sp"
            android:layout_marginTop="8dp"
            android:lineSpacingMultiplier="1.2" />

        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:background="@color/glass_white"
            android:layout_marginTop="16dp"
            android:layout_marginBottom="16dp" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Open Source Software • Licensed under GPL-3.0\nCreated by: Dhilip S"
            android:textColor="@color/text_secondary"
            android:textSize="12sp"
            android:gravity="center" />

        <!-- Warning Footer -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="⚠ SOS Alerter is a supplementary emergency tool and should not replace local emergency services."
            android:textColor="@color/panic_red"
            android:textSize="11sp"
            android:textStyle="bold"
            android:layout_marginTop="20dp"
            android:gravity="center"
            android:lineSpacingMultiplier="1.1" />

    </LinearLayout>
</ScrollView>
